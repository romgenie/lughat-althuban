{
  "comments": {
    "lineComment": "#"
  },
  "brackets": [
    ["(", ")"],
    ["[", "]"],
    ["{", "}"]
  ],
  "autoClosingPairs": [
    { "open": "(", "close": ")" },
    { "open": "[", "close": "]" },
    { "open": "{", "close": "}" },
    { "open": "\"", "close": "\"", "notIn": ["string"] },
    { "open": "'", "close": "'", "notIn": ["string"] },
    { "open": "«", "close": "»" }
  ],
  "surroundingPairs": [
    ["(", ")"],
    ["[", "]"],
    ["{", "}"],
    ["\"", "\""],
    ["'", "'"],
    ["«", "»"]
  ],
  "indentationRules": {
    "increaseIndentPattern": "^\\s*[^#].*:\\s*(#.*)?$",
    "decreaseIndentPattern": "^\\s*(وإلا|إلا_إذا|أخيرًا|إلا)\\b"
  },
  "onEnterRules": [
    {
      "beforeText": "^\\s*.*:\\s*(#.*)?$",
      "action": {
        "indent": "indent"
      }
    }
  ],
  "wordPattern": "[ء-يa-zA-Z_][ء-يa-zA-Z_٠-٩0-9]*"
}
